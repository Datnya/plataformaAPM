generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma/client"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── MODELS ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String?
  role      String   @default("CLIENTE") // ADMIN, CONSULTOR, CLIENTE
  status    String   @default("ACTIVO") // ACTIVO, INACTIVO
  companyId String?  @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company          Client?   @relation(fields: [companyId], references: [id])
  projects         Project[] @relation("ConsultantProjects")
  clientOfProjects Project[] @relation("ProjectClientUsers")
  timeLogs         TimeLog[]

  @@map("users")
}

model Client {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  status      String   @default("ACTIVO") // ACTIVO, INACTIVO
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users    User[]
  projects Project[]

  @@map("clients")
}

model Project {
  id           String   @id @default(uuid())
  name         String   @default("Proyecto sin nombre")
  clientId     String?  @map("client_id")
  consultantId String   @map("consultant_id")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client      Client?    @relation(fields: [clientId], references: [id])
  consultant  User       @relation("ConsultantProjects", fields: [consultantId], references: [id])
  clientUsers User[]     @relation("ProjectClientUsers")
  timeLogs    TimeLog[]
  goals       Goal[]
  activities  Activity[]

  @@map("projects")
}

model TimeLog {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id")
  consultantId String    @map("consultant_id")
  date         DateTime
  checkInTime  DateTime  @map("check_in_time")
  checkOutTime DateTime? @map("check_out_time")
  modality     String // PRESENCIAL, REMOTO
  areasVisited String    @map("areas_visited") // JSON stringified array
  peopleMet    String?   @map("people_met") // JSON stringified array
  evidenceUrls String    @map("evidence_urls") // JSON stringified array
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  project    Project @relation(fields: [projectId], references: [id])
  consultant User    @relation(fields: [consultantId], references: [id])

  @@map("time_logs")
}

model Goal {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  description String
  type        String // SEMANAL, MENSUAL
  status      String    @default("PENDIENTE") // PENDIENTE, EN_PROCESO, REVISION, COMPLETADO
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("goals")
}

model Activity {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  title       String
  description String?
  date        DateTime
  emails      String // JSON stringified array of emails
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("activities")
}

model Prospect {
  id                  String   @id @default(uuid())
  companyName         String   @map("company_name") // Razón social
  tradeName           String?  @map("trade_name") // Nombre comercial
  industry            String? // Rubro
  contactName         String   @map("contact_name") // Contacto (nombre y apellido)
  contactRole         String?  @map("contact_role") // Cargo
  phone               String? // Número de celular
  ruc                 String? // RUC
  email               String? // Correo
  notes               String? // Observaciones
  firstContactDate    DateTime @map("first_contact_date")
  lastInteractionDate DateTime @map("last_interaction_date")
  status              String   @default("NUEVO") // NUEVO, CONTACTADO, NEGOCIACION, CERRADO
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("prospects")
}

model AdminNote {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_notes")
}

model SocialContent {
  id          String   @id @default(uuid())
  networks    String // JSON string array e.g. ["LinkedIn", "Instagram"]
  contentType String   @map("content_type") // Informativo, Educativo, Inspirador, Promocional
  format      String // Reel, Carrusel, Post estático, Video largo
  publishDate DateTime @map("publish_date")
  status      String   @default("PENDIENTE") // PENDIENTE, EN_PROCESO, LANZADO
  title       String? // Opcional
  description String? // Opcional
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("social_contents")
}
